.PHONY: audit build check lint test verify

NPM ?= npm
override CONTINUOUS_CLI_USE_LIST_DISCOVERY :=
CONTINUOUS_CLI_ROOT_ID := 8f5148870e1d4b44b928c54e3e730882
CONTINUOUS_CLI_LIST_END := 76de24024a5f4d29a5c670339e0df168
CONTINUOUS_CLI_MAKEFILE_IDENTITY := CONTINUOUS_CLI_ROOT_ID := $(CONTINUOUS_CLI_ROOT_ID)
CONTINUOUS_CLI_LSOF_END := Z6bdb9d25d3a04de5904a0914bde64176
CONTINUOUS_CLI_DISCOVERY_MODULE := 

define continuous_cli_capture_make_381
node -e 'const Module=require("node:module"),helper=new Module("continuous-cli-descriptor-discovery");helper._compile(Buffer.from(process.argv[1],"base64").toString("utf8"),"continuous-cli-descriptor-discovery.js");helper.exports.runCli(process.argv.slice(2)).catch(()=>process.exit(1));' $(CONTINUOUS_CLI_DISCOVERY_MODULE) auto $$$$ $(CONTINUOUS_CLI_ROOT_ID) $(CONTINUOUS_CLI_LSOF_END)
endef

define continuous_cli_capture_make_382
node -e 'const Module=require("node:module"),helper=new Module("continuous-cli-makefile-list-discovery");helper._compile(Buffer.from(process.argv[1],"base64").toString("utf8"),"continuous-cli-makefile-list-discovery.js");helper.exports.runCli(process.argv.slice(2)).catch(()=>process.exit(1));' $(CONTINUOUS_CLI_DISCOVERY_MODULE) list self $(CONTINUOUS_CLI_ROOT_ID) $(CONTINUOUS_CLI_LSOF_END)
endef

define continuous_cli_capture_make_modern
sh -eu -c 'parse_file=$$1; identity=$$2; list_end=$$3; trap '\''rm -f -- "$$parse_file"'\'' EXIT HUP INT TERM; payload=$$({ cat "$$parse_file"; printf .; }); payload=$${payload%.}; payload=$${payload%?}; case $$payload in *"$$list_end") list=$${payload%"$$list_end"} ;; *) exit 1 ;; esac; candidate=$$list; count=0; channel=; while :; do if [ -f "$$candidate" ]; then case $$candidate in */*) root=$${candidate%/*}; [ -n "$$root" ] || root=/ ;; *) root=. ;; esac; if [ -f "$$root/.continuous-cli-root" ] && [ "$$(cat "$$root/.continuous-cli-root")" = "$$identity" ] && grep -Fqx "CONTINUOUS_CLI_ROOT_ID := $$identity" <"$$candidate"; then basename=$${candidate##*/}; CDPATH= cd -P -- "$$root"; makefile=$$PWD/$$basename; root_b64=$$(printf %s "$$PWD/." | base64 | tr -d "\n"); file_b64=$$(printf %s "$$makefile" | base64 | tr -d "\n"); channel=$$root_b64:$$file_b64; count=$$((count + 1)); fi; fi; case $$candidate in *" "*) candidate=$${candidate#* } ;; *) break ;; esac; done; [ "$$count" -eq 1 ]; printf %s "$$channel"' sh $(CONTINUOUS_CLI_PARSE_FILE) $(CONTINUOUS_CLI_ROOT_ID) $(CONTINUOUS_CLI_LIST_END)
endef

ifeq ($(MAKE_VERSION),3.81)
override CONTINUOUS_CLI_ROOT_CHANNEL := $(shell $(continuous_cli_capture_make_381))
else ifeq ($(MAKE_VERSION),3.82)
override CONTINUOUS_CLI_USE_LIST_DISCOVERY := 1
override CONTINUOUS_CLI_ROOT_CHANNEL :=
override CONTINUOUS_CLI_MAKEFILE_LIST = $(value MAKEFILE_LIST)
export CONTINUOUS_CLI_MAKEFILE_LIST
else
override CONTINUOUS_CLI_PARSE_FILE := $(shell mktemp "/tmp/continuous-cli-make-list.XXXXXX")
$(file >$(CONTINUOUS_CLI_PARSE_FILE),$(value MAKEFILE_LIST)$(CONTINUOUS_CLI_LIST_END))
override CONTINUOUS_CLI_ROOT_CHANNEL := $(shell $(continuous_cli_capture_make_modern))
endif

ifeq ($(strip $(CONTINUOUS_CLI_ROOT_CHANNEL)$(CONTINUOUS_CLI_USE_LIST_DISCOVERY)),)
$(error unable to establish the continuous-cli-101 Makefile identity)
endif

override CONTINUOUS_CLI_ROOT_CHANNEL := $(CONTINUOUS_CLI_ROOT_CHANNEL)
export NPM

ifeq ($(CONTINUOUS_CLI_USE_LIST_DISCOVERY),1)
define run_npm
	@channel=$$($(continuous_cli_capture_make_382)); sh -eu -c 'channel=$$1; [ -n "$$channel" ]; root_b64=$${channel%%:*}; makefile_b64=$${channel#*:}; root=$$(printf %s "$$root_b64" | base64 -d); makefile=$$({ printf %s "$$makefile_b64" | base64 -d; printf .; }); makefile=$${makefile%.}; [ -f "$$makefile" ]; CDPATH= cd -P -- "$$root"; [ "$$(cat .continuous-cli-root)" = "$(CONTINUOUS_CLI_ROOT_ID)" ]; grep -Fqx "$(CONTINUOUS_CLI_MAKEFILE_IDENTITY)" <"$$makefile"; exec "$$NPM" --prefix "$$PWD" $(1)' sh "$$channel"
endef
else
define run_npm
	@sh -eu -c 'channel=$$1; [ -n "$$channel" ]; root_b64=$${channel%%:*}; makefile_b64=$${channel#*:}; root=$$(printf %s "$$root_b64" | base64 -d); makefile=$$({ printf %s "$$makefile_b64" | base64 -d; printf .; }); makefile=$${makefile%.}; [ -f "$$makefile" ]; CDPATH= cd -P -- "$$root"; [ "$$(cat .continuous-cli-root)" = "$(CONTINUOUS_CLI_ROOT_ID)" ]; grep -Fqx "$(CONTINUOUS_CLI_MAKEFILE_IDENTITY)" <"$$makefile"; exec "$$NPM" --prefix "$$PWD" $(1)' sh "$(CONTINUOUS_CLI_ROOT_CHANNEL)"
endef
endif

lint:
	$(call run_npm,run lint)

test:
	$(call run_npm,test)

build:
	$(call run_npm,run check)

audit:
	$(call run_npm,run audit)

verify: lint test build audit

check: verify
