{
  "name": "continuous-cli101",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "lint": "eslint assets functions scripts --max-warnings=0",
    "test": "node scripts/test-functions.js",
    "check": "scripts/check-baseline.sh",
    "verify": "npm run lint && npm test && npm run check && npm run audit",
    "start": "twilio-run",
    "deploy": "twilio-run deploy",
    "audit": "npm audit --audit-level=moderate"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "eslint": "10.4.1",
    "twilio-run": "5.0.1"
  },
  "engines": {
    "node": "^22.13.0"
  },
  "overrides": {
    "title": "^4.0.1",
    "file-type": "^21.3.4"
  }
}
